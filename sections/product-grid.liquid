          "info": "Overrides the product's featured image in the grid."
        },
        {
          "type": "header",
          "content": "Hotspot Position — Desktop"
        },
        {
          "type": "range",
          "id": "hotspot_top_desktop",
          "label": "From top (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "hotspot_left_desktop",
          "label": "From left (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "header",
          "content": "Hotspot Position — Mobile"
        },
        {
          "type": "range",
          "id": "hotspot_top_mobile",
          "label": "From top (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        },
        {
          "type": "range",
          "id": "hotspot_left_mobile",
          "label": "From left (%)",
          "min": 0,
          "max": 100,
          "step": 1,
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shoppable Lookbook",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
